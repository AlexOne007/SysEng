              "    pm.response.to.have.status(201);\r",
              "});\r",
              "pm.test(\"Response has orderId\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.orderId).to.exist;\r",
              "    pm.collectionVariables.set(\"order_id\", jsonData.orderId);\r",
              "    console.log(\"Saved order_id:\", jsonData.orderId);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
